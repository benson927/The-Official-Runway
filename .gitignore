# =========================
# THE SILENT ARCHIVE IGNORE
# =========================

# 1. 環境變數與機密金鑰 (CRITICAL SECRETS)
.env
.env.local
.env.*

# 2. 後端快取與虛擬環境 (Python / Flask)
__pycache__/
*.pyc
*.pyo
venv/
.venv/
env/
instance/

# 3. 本地端快取資料庫 (SQLite)
*.db
*.sqlite3
runway_cache.db

# 4. 前端套件與編譯產物 (Node / React / Vite)
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. 作業系統雜訊 (OS Noise)
.DS_Store
Thumbs.db

# 6. 本地專屬筆記 (Local Startup Note)
start_note.md

# 7. 一鍵啟動腳本與日誌 (Startup script and logs)
start.sh
backend.log
frontend.log

# 8. 暫存錄影與開發套件 (Scratch videos & node modules)
scratch/node_modules/
scratch/videos/
